DEBUG=True
SECRET_KEY=change-me-in-production-use-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (DigitalOcean Docker) — див. .env.docker.example
# CSRF_TRUSTED_ORIGINS=https://svitpc.com.ua,https://www.svitpc.com.ua
# USE_HTTPS=true

# Database
DATABASE_URL=postgres://svitpc:svitpc@localhost:5432/svitpc
# Postgres FTS config name (default ukrainian — created by search migration)
POSTGRES_FTS_CONFIG=ukrainian

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Django language
LANGUAGE_CODE=uk

# Site
SITE_URL=http://localhost:8001
ADMIN_URL=admin/

# Brain API
BRAIN_LOGIN=
BRAIN_PASSWORD=
BRAIN_API_URL=https://api.brain.com.ua
# Hide Brain products when out of stock (is_archive)
BRAIN_HIDE_OUT_OF_STOCK=True
# /products page size: 100 (default API max without OWN_MODE), up to 1000 with OWN_MODE
BRAIN_PRODUCTS_PAGE_LIMIT=1000
# POST /products/content batch size (productIDs per request)
BRAIN_CONTENT_BATCH_SIZE=50
# Brain products use brain.com.ua prices directly (0 = no extra markup on top of Brain)
BRAIN_DEFAULT_MARKUP_PERCENT=0
# Top-level category slugs for Brain sync whitelist (comma-separated).
# Leave empty to use the built-in default (8 IT/stationery/school branches).
# BRAIN_ALLOWED_CATEGORY_SLUGS=ноутбуки-планшети,компютери-аксесуари,комплектуючі-до-пк,тб-аудіо-відео-фото,периферія-оргтехніка,мережеве-обладнання,канцтовари,товари-для-школи

# Kancmaster
# URL з логіном/паролем (query) або персональний export-URL від Kancmaster
KANCMASTER_XML_URL=https://kancmaster.com.ua/export/kancmaster.xml
KANCMASTER_LOGIN=
KANCMASTER_PASSWORD=

# Nova Poshta
NOVA_POSHTA_API_KEY=
# Nova Poshta sender (required for TTN creation — get from NP personal cabinet)
NP_SENDER_REF=
NP_SENDER_CONTACT_REF=
NP_SENDER_PHONE=
NP_SENDER_CITY_REF=
NP_SENDER_WAREHOUSE_REF=

# Payments — LiqPay
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
# Full HTTPS URL LiqPay will POST webhook to (cannot be localhost)
# Example: https://yourdomain.com/webhooks/liqpay/
LIQPAY_SERVER_URL=
LIQPAY_SANDBOX=True

# Payments — WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=

# Payments — Monobank (Mono Parts)
MONOBANK_TOKEN=

# Vchasno.Kasa (токен каси з kasa.vchasno.ua → Торгові точки → ⚙️ → Токен)
VCHASNO_CASHBOX_KEY=
VCHASNO_DEVICE_NAME=SvitPC
VCHASNO_TAX_GRP=1

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_LINK=https://t.me/your_bot_username

# Viber bot (https://developers.viber.com)
VIBER_BOT_TOKEN=

# AI (OpenAI-compatible endpoint — content gen, consultant, EN translation via --backend=llm)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
# AI-консультант на сайті (кнопки в хедері, PDP, футері). За замовчуванням вимкнено.
AI_CONSULTANT_ENABLED=False

# VAPID for web push
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@svitpc.ua

# Google
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
GOOGLE_ADS_ID=
ANALYTICS_FEED_MAX_PRODUCTS=10000

# Email — Resend SMTP (https://resend.com/docs/send-with-django-smtp)
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxx
# DEFAULT_FROM_EMAIL=orders@svitpc.com.ua
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@svitpc.ua

# SMS — TurboSMS (https://turbosms.ua → Налаштування → HTTP API)
# Увімкніть HTTP API, скопіюйте токен у SMS_API_KEY.
# SMS_SENDER має збігатися з активним альфа-іменем у кабінеті TurboSMS.
# Перевірка: make test-sms  або  make test-sms PHONE=+380501234567
SMS_API_KEY=
SMS_SENDER=SvitPC

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ── Docker / DigitalOcean ─────────────────────────────────────────────────────
# Локально: docker compose up --build
# Production на Droplet: cp .env.docker.example .env && bash deploy/docker/deploy.sh
# Деталі: .env.docker.example, deploy/nginx/docker.prod.conf
