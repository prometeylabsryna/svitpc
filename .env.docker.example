# ── DigitalOcean production (.env на сервері, не комітити) ─────────────────────
# cp .env.docker.example .env && nano .env

DEBUG=False
SECRET_KEY=change-me-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.docker

# До SSL: USE_HTTPS=false, SITE_URL=http://YOUR_DROPLET_IP або http://svitpc.com.ua
# Після certbot: USE_HTTPS=true, SITE_URL=https://svitpc.com.ua
USE_HTTPS=false
SITE_URL=https://svitpc.com.ua

POSTGRES_DB=svitpc
POSTGRES_USER=svitpc
POSTGRES_PASSWORD=strong-password-here
DATABASE_URL=postgres://svitpc:strong-password-here@db:5432/svitpc

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Домен, IP Droplet, web (internal healthcheck), localhost
ALLOWED_HOSTS=svitpc.com.ua,www.svitpc.com.ua,127.0.0.1,localhost,backend
CSRF_TRUSTED_ORIGINS=https://svitpc.com.ua,https://www.svitpc.com.ua

ADMIN_URL=admin/
LANGUAGE_CODE=uk
POSTGRES_FTS_CONFIG=ukrainian

HTTP_PORT=80

# ── Brain API ──────────────────────────────────────────────────────────────────
BRAIN_LOGIN=
BRAIN_PASSWORD=
BRAIN_API_URL=https://api.brain.com.ua
BRAIN_HIDE_OUT_OF_STOCK=True

# ── Kancmaster ─────────────────────────────────────────────────────────────────
KANCMASTER_XML_URL=https://kancmaster.com.ua/export/kancmaster.xml
KANCMASTER_LOGIN=
KANCMASTER_PASSWORD=

# ── Nova Poshta ────────────────────────────────────────────────────────────────
NOVA_POSHTA_API_KEY=
NP_SENDER_REF=
NP_SENDER_CONTACT_REF=
NP_SENDER_PHONE=
NP_SENDER_CITY_REF=
NP_SENDER_WAREHOUSE_REF=

# ── Ukrposhta ──────────────────────────────────────────────────────────────────
UKRPOSHTA_BEARER=
UKRPOSHTA_TOKEN=
UP_SENDER_CLIENT_UUID=
UP_SENDER_POSTCODE=
UP_SENDER_ADDRESS=
UP_SENDER_CITY=

# ── Payments ───────────────────────────────────────────────────────────────────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SERVER_URL=https://svitpc.com.ua/webhooks/liqpay/
LIQPAY_SANDBOX=False

WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=

MONOBANK_TOKEN=

# ── Vchasno.Kasa ───────────────────────────────────────────────────────────────
VCHASNO_CASHBOX_KEY=
VCHASNO_DEVICE_NAME=SvitPC
VCHASNO_TAX_GRP=1

# ── Bots ───────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_LINK=https://t.me/your_bot_username
VIBER_BOT_TOKEN=

# ── AI ─────────────────────────────────────────────────────────────────────────
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
AI_CONSULTANT_ENABLED=False

# ── Web Push ───────────────────────────────────────────────────────────────────
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@svitpc.ua

# ── Analytics ──────────────────────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
ANALYTICS_FEED_MAX_PRODUCTS=10000

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@svitpc.ua

# ── SMS (TurboSMS) ─────────────────────────────────────────────────────────────
SMS_API_KEY=
SMS_SENDER=SvitPC

# ── Gunicorn (2 GB RAM: GUNICORN_WORKERS=2) ───────────────────────────────────
GUNICORN_WORKERS=3
